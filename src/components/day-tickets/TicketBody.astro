---
import { format } from 'date-fns';
import { marked } from 'marked';
type Props = {
  title: string;
  body: string;
  createdDate: Date;
  writtenDate: Date;
};

const { title, body, createdDate, writtenDate } = Astro.props;

const content = marked.parse(body, {
  breaks: true,
  mangle: false,
  headerIds: false,
});

type NewContent = {
  finalContent: string;
  hasIndents: boolean;
  needsWrapping: boolean;
};

const createContent = (content: string): NewContent => {
  let finalContent = content;

  // from what I can foresee you'll never need wrapping
  // as well as indents, as the whole point of wrapping
  // is you're creating a block of text, but who knows
  const needsWrapping = content.startsWith('<p>-wrap-');
  if (needsWrapping) {
    finalContent = content.replace('-wrap-', '').trim();
  }

  const hasIndents = content.startsWith('<p>-indents-');
  if (hasIndents) {
    finalContent = content.replace('-indents-', '').trim();
  }

  return { finalContent, hasIndents, needsWrapping };
};

const createFinalClasses = (content: NewContent) => {
  let classes = '';

  if (content.needsWrapping) {
    classes += 'wrap';
  } else if (content.hasIndents) {
    classes += 'poem';
  } else {
    classes += 'nowrap';
  }

  return classes;
};

const newContent = createContent(content);
const finalClasses = createFinalClasses(newContent);
---

<div>
  <h3>{title}</h3>

  <article set:html={newContent.finalContent} class={finalClasses} />

  <div class="info">
    <span>- Elijah James-Hallows</span>
    <div>
      <span>Written: {format(new Date(writtenDate), 'dd/MM/yyyy')}</span>
      <span>Published: {format(new Date(createdDate), 'dd/MM/yyyy')}</span>
    </div>
  </div>
</div>

<style lang="scss" is:inline>
  div {
    padding: 0 0.4rem;
    font-family: sinter, sans-serif;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 1rem;
    max-width: 40rem;
  }

  .poem {
    white-space: pre-wrap;
  }

  .wrap {
    white-space: wrap;
  }

  .nowrap {
    white-space: nowrap;
  }

  h3 {
    font-family: sinter, sans-serif;
    font-size: 2rem;
  }

  article > p {
    font-size: 1.4rem;
    line-height: 2rem;

    margin-bottom: 1.5rem;

    @media (max-width: 25em) {
      font-size: 1.2rem;
    }
  }

  .info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  span {
    font-size: 1.4rem;
  }
</style>
